{
    "version": "5.7.6",
    "description": "USB Drive Info is an USB Drive Information Tool for Windows.",
    "homepage": "https://www.uwe-sieber.de/usbdriveinfo_e.html",
    "license": "Freeware",
    "architecture": {
        "64bit": {
            "url": "https://www.uwe-sieber.de/files/UsbDriveInfo576_x64.zip",
            "hash": "66ac7cf8a3ad7a10f09e7292ec7ce9bc88140245a387eebf408c49c2d47c123c"
        },
        "32bit": {
            "url": "https://www.uwe-sieber.de/files/UsbDriveInfo576_Win32.zip",
            "hash": "0001139a14b9ca0fb4cef8fe8b7e4c69932f00cb158b6c0d3b93ba826e80d43d"
        }
    },
    "shortcuts": [
        [
            "UsbDriveInfo.exe",
            "USB Drive Info"
        ]
    ],
    "pre_install": "if (!(Test-Path \"$persist_dir\\UsbDriveInfo.ini\")) { Set-Content -Encoding ASCII -Path \"$dir\\UsbDriveInfo.ini\" -Value $null }",
    "persist": "UsbDriveInfo.ini",
    "checkver": {
        "regex": "USB Drive Info V([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://www.uwe-sieber.de/files/UsbDriveInfo$cleanVersion_x64.zip"
            },
            "32bit": {
                "url": "https://www.uwe-sieber.de/files/UsbDriveInfo$cleanVersion_Win32.zip"
            }
        }
    }
