{
    "version": "2.9.2",
    "description": "极速秒存的私人云盘，在电脑上轻松使用",
    "homepage": "https://mypikpak.com/",
    "license": "Proprietary",
    "architecture": {
        "64bit": {
            "url": "https://download.mypikpak.net/desktop/official_PikPak.exe#/dl.7z",
            "pre_install": "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
            "hash": "0cdd13b6a9b667db72872ab2631612d984b2361fdc348de6f4e3647180d1ed0f"
        }
    },
    "shortcuts": [
        [
            "PikPak.exe",
            "PikPak"
        ]
    ],
    "post_install": "Remove-Item \"$dir\\uninstall*\", \"$dir\\`$*\" -Force -Recurse -ErrorAction SilentlyContinue",
    "post_uninstall": "if ($purge) { Remove-Item \"$env:APPDATA\\PikPak\", \"$env:PUBLIC\\PikPak\" -Force -Recurse -ErrorAction SilentlyContinue }",
    "notes": [
        "PikPak is NOT portable.",
        "Settings are stored in '%APPDATA%\\PikPak', and can be purged using 'scoop uninstall --purge pikpak'."
    ],
    "checkver": {
        "script": "try { & $dir\\..\\bin\\Get-DumplingsVersion.ps1 -Verbose -PreferRealVersion -AppName 'PIKCLOUD.PikPak' } catch { \"\" }",
        "regex": "^([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://download.mypikpak.net/desktop/official_PikPak.exe#/dl.7z"
            }
        }
    }
}
