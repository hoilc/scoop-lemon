            "hash": "dcda2c1ada2472bc85cd73c070e2a13b1abd9cc424a000c69747bda218790773"
        },
        "arm64": {
            "url": "https://github.com/zerx-lab/FluxDown/releases/download/v0.2.4-rc.2/FluxDown-0.2.4-rc.2-windows-arm64-portable.zip",
            "hash": "9df5f13885062bee43ea4d6be0e23d1bf9fc23d6afb895ca012771b9a775d3b8"
        }
    },
    "shortcuts": [
        [
            "flux_down.exe",
            "FluxDown"
        ]
    ],
    "persist": "portable_data",
    "post_install": "Remove-Item \"$dir\\fluxdown_updater.exe\" -Force -ErrorAction SilentlyContinue",
    "post_uninstall": [
        "if ($purge) { Remove-Item -Path 'HKCU:\\Software\\Google\\Chrome\\NativeMessagingHosts\\com.fluxdown.nmh', 'HKCU:\\Software\\Microsoft\\Edge\\NativeMessagingHosts\\com.fluxdown.nmh', 'HKCU:\\Software\\Mozilla\\NativeMessagingHosts\\com.fluxdown.nmh' -Recurse -ErrorAction SilentlyContinue }",
        "if ($purge) { Remove-ItemProperty -Path 'HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Run' -Name 'FluxDown' -ErrorAction SilentlyContinue }",
        "if ($purge) { Remove-Item -Path 'HKCU:\\Software\\Classes\\fluxdown' -Recurse -ErrorAction SilentlyContinue }",
        "if ($purge) { if ((Get-ItemProperty 'HKCU:\\Software\\Classes\\.torrent' -ErrorAction SilentlyContinue).'(default)' -eq 'FluxDown.TorrentFile') { Remove-Item 'HKCU:\\Software\\Classes\\.torrent', 'HKCU:\\Software\\Classes\\FluxDown.TorrentFile' -Recurse -ErrorAction SilentlyContinue } }"
    ],
    "checkver": {
        "url": "https://github.com/zerx-lab/FluxDown/releases.atom",
        "regex": "Repository/\\d+/v(.+?)<"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/zerx-lab/FluxDown/releases/download/v$version/FluxDown-$version-windows-x64-portable.zip"
            },
            "arm64": {
                "url": "https://github.com/zerx-lab/FluxDown/releases/download/v$version/FluxDown-$version-windows-arm64-portable.zip"
            }
        },
        "hash": {
            "url": "$baseurl/SHA256SUMS.txt"
        }
    }
}
