    "bin": "ffdec-cli.bat",
    "shortcuts": [
        [
            "ffdec.bat",
            "JPEXS Free Flash Decompiler",
            "",
            "icon.ico"
        ]
    ],
    "pre_install": [
        "(Get-Content -Raw \"$dir\\ffdec.bat\") -replace '\\njava ', 'start javaw ' | Set-Content \"$dir\\ffdec.bat\"",
        "@($manifest.bin) | ForEach-Object { $n = [IO.Path]::GetFileNameWithoutExtension($_); Set-Content -Encoding ASCII -Path \"$dir\\$n.bat\" -Value \"@java -jar `\"%~dp0$n.jar`\" %*\" }"
    ],
    "suggest": {
        "JDK": [
            "java/temurin-jdk",
            "java/zulu-jdk"
        ]
    },
    "notes": "You need to have JRE 8+ installed on your computer to use JPEXS Free Flash Decompiler.",
    "checkver": {
        "url": "https://github.com/jindrapetrik/jpexs-decompiler/releases.atom",
        "regex": "Repository/\\d+/version([\\d.]+)"
    },
    "autoupdate": {
        "url": "https://github.com/jindrapetrik/jpexs-decompiler/releases/download/version$version/ffdec_$version.zip"
    }
}
