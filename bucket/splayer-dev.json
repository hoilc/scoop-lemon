    "homepage": "https://github.com/imsyy/SPlayer",
    "license": "AGPL-3.0-only",
    "architecture": {
        "64bit": {
            "url": "https://nightly.link/imsyy/SPlayer/actions/runs/23060863234/SPlayer-Windows-setup-x64.zip",
            "hash": "a2ef5818a50482958697af6d5cbd4e5b5415e4f58561122008a536d05d1f6a03",
            "pre_install": [
                "Get-ChildItem \"$dir\" 'SPlayer-*-x64-setup.exe' | Select-Object -First 1 -ExpandProperty FullName | Expand-7zipArchive -Destination \"$dir\" -Removal",
                "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\""
            ]
        },
        "arm64": {
            "url": "https://nightly.link/imsyy/SPlayer/actions/runs/23060863234/SPlayer-Windows-setup-arm64.zip",
            "hash": "012c0ed993e278b20f2b1953418b73c19ce63fe1e595dfb8a6809b4a23f90cc2",
            "pre_install": [
                "Get-ChildItem \"$dir\" 'SPlayer-*-arm64-setup.exe' | Select-Object -First 1 -ExpandProperty FullName | Expand-7zipArchive -Destination \"$dir\" -Removal",
                "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-arm64.7z\" \"$dir\""
            ]
        }
    },
    "post_install": "Remove-Item \"$dir\\SPlayer?*.exe\", \"$dir\\uninstall*\", \"$dir\\`$*\", \"$dir\\resources\\app-update.yml\" -Force -Recurse -ErrorAction SilentlyContinue",
    "shortcuts": [
        [
            "SPlayer.exe",
            "SPlayer Dev",
            "--user-data-dir=\"User Data\""
        ]
    ],
    "persist": "User Data",
    "checkver": {
        "url": "https://github.com/imsyy/SPlayer/actions?query=branch%3Adev+is%3Asuccess+event%3Apush",
        "regex": "(?sm)/actions/runs/(?<run>\\d+)\".*?#(?<build>\\d+):",
        "replace": "b${build}"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://nightly.link/imsyy/SPlayer/actions/runs/$matchRun/SPlayer-Windows-setup-x64.zip"
            },
            "arm64": {
                "url": "https://nightly.link/imsyy/SPlayer/actions/runs/$matchRun/SPlayer-Windows-setup-arm64.zip"
            }
        }
    }
}
