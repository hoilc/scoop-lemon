            "pre_install": [
                "Get-ChildItem \"$dir\" 'SPlayer-*-x64-setup.exe' | Select-Object -First 1 -ExpandProperty FullName | Expand-7zipArchive -Destination \"$dir\" -Removal",
                "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\""
            ]
        },
        "arm64": {
            "url": "https://nightly.link/imsyy/SPlayer/actions/runs/23123757574/SPlayer-Windows-setup-arm64.zip",
            "hash": "995b3999b3a6a618b5bf51eff42e3e1dd872ddc50fff30f8d503f0661e3cc38e",
            "pre_install": [
                "Get-ChildItem \"$dir\" 'SPlayer-*-arm64-setup.exe' | Select-Object -First 1 -ExpandProperty FullName | Expand-7zipArchive -Destination \"$dir\" -Removal",
                "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-arm64.7z\" \"$dir\""
            ]
        }
    },
    "post_install": "Remove-Item \"$dir\\SPlayer?*.exe\", \"$dir\\uninstall*\", \"$dir\\`$*\", \"$dir\\resources\\app-update.yml\" -Force -Recurse -ErrorAction SilentlyContinue",
    "shortcuts": [
        [
            "SPlayer.exe",
            "SPlayer Dev",
            "--user-data-dir=\"User Data\""
        ]
    ],
    "persist": "User Data",
    "checkver": {
        "url": "https://github.com/imsyy/SPlayer/actions?query=branch%3Adev+is%3Asuccess+event%3Apush",
