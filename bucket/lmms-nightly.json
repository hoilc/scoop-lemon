{
    "version": "1.3.0-alpha.1.1021+795d39d",
    "description": "(Nightly Build) A free, open source, multiplatform digital audio workstation.",
    "homepage": "https://lmms.io/",
    "license": "GPL-2.0-or-later",
    "architecture": {
        "64bit": {
            "url": "https://lmms.io/download/artifact/8472806171#/dl.7z",
            "hash": "94b0f98ed8263ec889336026027d762f941b780c5f2ebaa743d7229a299b5665"
        },
        "arm64": {
            "url": "https://lmms.io/download/artifact/8472762330#/dl.7z",
            "hash": "e815172fe9fb21afff5f2c560a2f3a9f142a261c38620e4accd8857015350a19"
        }
    },
    "post_install": "Remove-Item \"$dir\\`$PLUGINSDIR\" -Force -Recurse",
    "shortcuts": [
        [
            "lmms.exe",
            "LMMS Nightly"
        ]
    ],
    "checkver": {
        "script": [
            "try {",
            "    $workflows = Invoke-RestMethod 'https://api.github.com/repos/LMMS/lmms/actions/workflows/build.yml/runs?event=push&branch=master&status=success&per_page=1'",
            "    $artifacts = Invoke-RestMethod ($workflows.workflow_runs[0].url + '/artifacts')",
            "    $x64 = $artifacts.artifacts | Where-Object { $_.name -like '*msvc2022-win64*' } | Select-Object -First 1",
            "    $arm64 = $artifacts.artifacts | Where-Object { $_.name -like '*mingw-arm64*' } | Select-Object -First 1",
            "} catch { Write-Host $_.Exception.Message }",
            "return \"{0}|{1}|{2}\" -f $x64.id, $arm64.id, $x64.name"
        ],
        "regex": "(?<x64id>\\d+)\\|(?<arm64id>\\d+)\\|lmms-(.+?)-msvc2022-win64"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://lmms.io/download/artifact/$matchX64id#/dl.7z"
            },
            "arm64": {
                "url": "https://lmms.io/download/artifact/$matchArm64id#/dl.7z"
            }
        }
    }
}
