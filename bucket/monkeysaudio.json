        [
            "Monkey's Audio.exe",
            "Monkey's Audio"
        ]
    ],
    "checkver": {
        "url": "https://monkeysaudio.com/versionhistory.html",
        "regex": "Version\\s*([\\d.-]+)"
    },
    "autoupdate": {
