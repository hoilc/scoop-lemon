{
    "version": "b4320",
    "description": "(Nightly Build) A customisable music player.",
    "homepage": "https://github.com/fooyin/fooyin",
    "license": "GPL-3.0-only",
    "architecture": {
        "64bit": {
            "url": "https://nightly.link/fooyin/fooyin/actions/runs/25294588002/windows-portable-amd64.zip",
            "hash": "e6560f0e225af21fca95fc31df8d7937b36c9112741779ddcefde030e319c715"
        },
        "arm64": {
            "url": "https://nightly.link/fooyin/fooyin/actions/runs/25294588002/windows-portable-arm64.zip",
            "hash": "0d38e36c6e1a513151a31a87393aacb857ee8f3de474054cef82fc4851dd5f49"
        }
    },
    "pre_install": [
        "Remove-Item \"$dir\\fooyin-*.exe\" -ErrorAction SilentlyContinue",
        "$zipfile = Get-ChildItem \"$dir\" 'fooyin-*.zip' | Select-Object -First 1",
        "if (!$zipfile) { error 'Failed to find portable package file.' ; exit }",
        "Expand-7zipArchive -Path $zipfile.FullName -Destination \"$dir\" -Removal -ExtractDir $zipfile.BaseName"
    ],
    "shortcuts": [
        [
            "fooyin.exe",
            "fooyin"
        ]
    ],
    "persist": [
        "data",
        "config",
        "cache"
    ],
    "checkver": {
        "url": "https://github.com/fooyin/fooyin/actions/workflows/build.yml?query=event%3Apush+is%3Asuccess+branch%3Amaster",
        "regex": "(?sm)/actions/runs/(?<run>\\d+)\".*?#(?<build>\\d+):",
        "replace": "b${build}"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://nightly.link/fooyin/fooyin/actions/runs/$matchRun/windows-portable-amd64.zip"
            },
            "arm64": {
                "url": "https://nightly.link/fooyin/fooyin/actions/runs/$matchRun/windows-portable-arm64.zip"
            }
        },
        "hash": {
            "url": "https://api.github.com/repos/fooyin/fooyin/actions/runs/$matchRun/artifacts",
            "regex": "(?sm)$basenameNoExt.*?sha256:$sha256"
        }
    }
}
