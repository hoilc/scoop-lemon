{
    "version": "0.15.0",
    "description": "Spring Boot Migrator (SBM) is a tool for automated code migrations to upgrade or migrate to Spring Boot.",
    "homepage": "https://github.com/spring-projects-experimental/spring-boot-migrator",
    "license": "Apache-2.0",
    "url": "https://github.com/spring-projects-experimental/spring-boot-migrator/releases/download/0.15.0/spring-boot-migrator.jar#/sbm.jar",
    "hash": "8055c658187f1e5dfa71f934d3d3cd24dad46796c8b2f69246153fdb6dbcc55b",
    "pre_install": "@($manifest.bin) | ForEach-Object { $n = [IO.Path]::GetFileNameWithoutExtension($_); Set-Content -Encoding ASCII -Path \"$dir\\$n.bat\" -Value \"@java -jar `\"%~dp0$n.jar`\" %*\" }",
    "bin": "sbm.bat",
    "suggest": {
        "JDK 17+": [
            "java/temurin17-jdk",
            "java/zulu17-jdk"
        ]
    },
    "checkver": "github",
    "autoupdate": {
        "url": "https://github.com/spring-projects-experimental/spring-boot-migrator/releases/download/$version/spring-boot-migrator.jar#/sbm.jar"
    }
}
