{
    "##": "The shortcut will be created when adding the Appx package",
    "version": "26.7.10.1209",
    "description": "A Windows Event Log viewer for tech support and IT professionals.",
    "homepage": "https://github.com/microsoft/EventLogExpert",
    "license": "MIT",
    "url": "https://github.com/microsoft/EventLogExpert/releases/download/v26.7.10.1209/EventLogExpert_26.7.10.1209.msixbundle#/EventLogExpert.msixbundle",
    "hash": "0bea34b5699c2788934cb60cb3a5cc06668fcf25eecfd5ddc2bf2fc01a9f4499",
    "installer": {
        "script": [
            "if ($env:CI -eq \"true\") { Return }",
            "if ($PSVersionTable.PSVersion.Major -ge 6) { Import-Module Appx -UseWindowsPowershell 3>$null }",
            "Add-AppxPackage \"$dir\\EventLogExpert.msixbundle\" -ForceTargetApplicationShutdown"
        ]
    },
    "uninstaller": {
        "script": [
            "if ($env:CI -eq \"true\") { Return }",
            "if ($cmd -eq \"update\") { Write-Host \"Skipping uninstallation because of update operation...\" ; Return }",
            "if ($PSVersionTable.PSVersion.Major -ge 6) { Import-Module Appx -UseWindowsPowershell 3>$null }",
            "$package = Get-AppxPackage 'eventlogexpert'",
            "if (!$package) { warn \"$app is already uninstalled out of scoop.\" ; return }",
            "if ($purge) {",
            "    Remove-AppxPackage $package",
            "} else {",
            "    Remove-AppxPackage $package -PreserveRoamableApplicationData",
            "}"
        ]
    },
    "checkver": "github",
    "autoupdate": {
        "url": "https://github.com/microsoft/EventLogExpert/releases/download/v$version/EventLogExpert_$version.msixbundle#/EventLogExpert.msixbundle"
    }
}
