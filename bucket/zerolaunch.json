    "pre_install": [
        "if (!(Test-Path \"$persist_dir\\ZeroLaunch_local_config.json\")) { Set-Content -Encoding ASCII -Path \"$dir\\ZeroLaunch_local_config.json\" -Value '{}' }",
        "if (!(Test-Path \"$persist_dir\\ZeroLaunch_remote_config.json\")) { Set-Content -Encoding ASCII -Path \"$dir\\ZeroLaunch_remote_config.json\" -Value '{}' }",
        "if (!(Test-Path \"$persist_dir\\background.png\")) { Set-Content -Encoding ASCII -Path \"$dir\\background.png\" -Value $null }"
    ],
    "persist": [
        "logs",
        "icons",
        "models",
        "ZeroLaunch_local_config.json",
        "ZeroLaunch_remote_config.json",
        "background.png"
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
