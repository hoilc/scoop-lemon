    "pre_install": [
        "Get-ChildItem \"$dir\" 'ImageSearch_*.exe' | Select-Object -First 1 | Rename-Item -NewName 'ImageSearch.exe'",
        "Get-ChildItem \"$dir\" '以图搜图*.exe' | Select-Object -First 1 | Rename-Item -NewName 'ImageSearch.exe'"
