{
    "version": "1.9.1-beta-r321",
    "description": "An open-source registry compare utility that allows you to quickly take a snapshot of your registry and then compare it with a second one.",
    "homepage": "https://sourceforge.net/projects/regshot/",
    "license": "LGPL-2.1-only",
    "url": "https://sourceforge.net/projects/regshot/files/regshot/1.9.1-beta/Regshot-1.9.1-beta_r321.7z",
    "hash": "sha1:f01136a342916987299caae254e8d56f79973791",
    "architecture": {
        "64bit": {
            "installer": {
                "script": [
                    "Rename-Item -Path \"$dir\\Regshot-x64-Unicode.exe\" -NewName 'Regshot.exe'",
                    "Remove-Item \"$dir\\Regshot?*.exe\" -Force"
                ]
            }
        },
        "32bit": {
            "installer": {
                "script": [
                    "Rename-Item -Path \"$dir\\Regshot-x86-Unicode.exe\" -NewName 'malm.exe'",
                    "Remove-Item \"$dir\\Regshot?*.exe\" -Force"
                ]
            }
        }
    },
    "shortcuts": [
        [
            "Regshot.exe",
            "Regshot"
        ]
    ],
    "persist": "regshot.ini"
}
