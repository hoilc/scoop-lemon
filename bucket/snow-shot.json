{
    "version": "0.9.0-beta",
    "description": "SnowShot 是一款功能强大的截图工具，集成了文字识别、翻译和 AI 对话等功能",
    "homepage": "https://github.com/xiaofeiTM233/snow-shot",
    "license": "Apache-2.0|GPL-3.0-only",
    "architecture": {
        "64bit": {
            "url": "https://cnb.cool/ycawa/snow-shot/-/releases/download/v0.9.0-beta/Snow.Shot_0.9.0-beta_windows-x64_offline_setup.exe#/dl.7z",
            "hash": "f5acac128cfbee17cb442485bb0568abf228159c516557bc74d68284bd6f0c5b"
        }
    },
    "shortcuts": [
        [
            "snowshot.exe",
            "Snow Shot"
        ]
    ],
    "pre_install": "if (!(Test-Path \"$dir\\__portable\")) { Set-Content -Encoding ASCII -Path \"$dir\\__portable\" -Value $null }",
    "post_install": "Remove-Item \"$dir\\uninstall*\", \"$dir\\`$*\" -Force -Recurse -ErrorAction SilentlyContinue",
    "post_uninstall": "if ($purge) { Remove-Item \"$env:LOCALAPPDATA\\com.chao.snowshot\" -Force -Recurse -ErrorAction SilentlyContinue }",
    "persist": [
        "configs",
        "plugins",
        "stores",
        "captureHistoryImages",
        "pluginsDownloads"
    ],
    "checkver": {
        "url": "https://github.com/xiaofeiTM233/snow-shot/releases.atom",
        "regex": "Repository/\\d+/v(.+?)<"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://cnb.cool/ycawa/snow-shot/-/releases/download/v$version/Snow.Shot_$version_windows-x64_offline_setup.exe#/dl.7z"
            }
        }
    }
}
