{
    "version": "1.0.2",
    "description": "A feature-rich open-source AI chat platform with powerful search enhancement and tool calling capabilities.",
    "homepage": "https://deepchat.thinkinai.xyz/",
    "license": "Apache-2.0",
    "architecture": {
        "64bit": {
            "url": "https://cdn.deepchatai.cn/download/v1.0.2/DeepChat-1.0.2-windows-x64.exe#/dl.7z",
            "pre_install": "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
            "hash": "c70ef0a4c41292a722751319272b2538b40e79ad0d016ff40e025189774943b4"
        }
    },
    "post_install": "Remove-Item \"$dir\\`$*\", \"$dir\\resources\\app-update.yml\" -Force -Recurse -ErrorAction SilentlyContinue",
    "shortcuts": [
        [
            "DeepChat.exe",
            "DeepChat",
            "--user-data-dir=\"User Data\""
        ]
    ],
    "persist": "User Data",
    "checkver": {
        "url": "https://cdn.deepchatai.cn/download/version.json",
        "jsonpath": "$.release",
        "regex": "^([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://cdn.deepchatai.cn/download/v$version/DeepChat-$version-windows-x64.exe#/dl.7z"
            }
        }
    }
}
