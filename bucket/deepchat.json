    "architecture": {
        "64bit": {
            "url": "https://cdn.deepchatai.cn/download/v1.0.7/DeepChat-1.0.7-windows-x64.exe#/dl.7z",
            "pre_install": "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
            "hash": "49fb50d9b443b026f9e01a1c6c3fc6849308ee4a5e579dafb9bdd1aa03a8815f"
        },
        "arm64": {
            "url": "https://cdn.deepchatai.cn/download/v1.0.7/DeepChat-1.0.7-windows-arm64.exe#/dl.7z",
            "pre_install": "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-arm64.7z\" \"$dir\"",
            "hash": "7844c66ff46897323d1cb69f7d2495aa6fb22b12693e53358f7fc2477921a674"
        }
    },
    "post_install": "Remove-Item \"$dir\\`$*\", \"$dir\\resources\\app-update.yml\" -Force -Recurse -ErrorAction SilentlyContinue",
    "shortcuts": [
        [
            "DeepChat.exe",
            "DeepChat",
            "--user-data-dir=\"User Data\""
        ]
    ],
    "persist": "User Data",
    "checkver": {
        "url": "https://cdn.deepchatai.cn/download/version.json",
        "jsonpath": "$.release",
        "regex": "^([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://cdn.deepchatai.cn/download/v$version/DeepChat-$version-windows-x64.exe#/dl.7z"
            },
            "arm64": {
                "url": "https://cdn.deepchatai.cn/download/v$version/DeepChat-$version-windows-arm64.exe#/dl.7z"
            }
        }
    }
}
