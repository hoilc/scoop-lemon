{
    "version": "0.3.9",
    "description": "Copicseal（可图匠）是一个图片加边框水印工具，支持读取 EXIF 信息",
    "homepage": "https://copicseal.kohai.top/",
    "license": "Apache-2.0",
    "architecture": {
        "64bit": {
            "url": "https://github.com/copicseal/copicseal/releases/download/v0.3.9/copicseal-0.3.9-setup.exe#/dl.7z",
            "pre_install": "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
            "hash": "sha512:d90d8fead910b894d19f06037aec68b4cfc86551bb87e2aed559b3d7ad2acf5aa8e703d6fd62256c21e820c1dfb4d88887b3437b5cbfe59df199333826b825fa"
        }
    },
    "post_install": "Remove-Item \"$dir\\`$*\", \"$dir\\resources\\app-update.yml\" -Force -Recurse",
    "shortcuts": [
        [
            "copicseal.exe",
            "Copicseal",
            "--user-data-dir=\"User Data\""
        ]
    ],
    "persist": "User Data",
    "checkver": {
        "github": "https://github.com/copicseal/copicseal"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/copicseal/copicseal/releases/download/v$version/copicseal-$version-setup.exe#/dl.7z"
            }
        },
        "hash": {
            "url": "$baseurl/latest.yml",
            "regex": "(?sm)$basename\\s*sha512:\\s*$base64"
        }
    }
}
