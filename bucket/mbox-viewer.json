            "MBox Viewer"
        ]
    ],
    "post_install": "if (!(Test-Path \"$persist_dir\\Config\\MBoxViewer.config\")) { Copy-Item \"$dir\\Config\\MBoxViewer.config.sample\" \"$dir\\Config\\MBoxViewer.config\" | Out-Null }",
