{
    "version": "6.12.0",
    "description": "A personal music streaming server.",
    "homepage": "http://mstream.io/",
    "license": "GPL-3.0-only",
    "architecture": {
        "64bit": {
            "url": "https://github.com/IrosTheBeggar/mStream/releases/download/v6.12.0/mStream-Server-Setup-6.12.0.exe#/dl.7z",
            "hash": "sha512:b22f4663db606274253dd212e71d3f2422c4a3ab2b393488997d043d46b4b504b2db22655df54548f0d6f79b2500a53a59f082007788d9f1372575cbf3473d47",
            "pre_install": "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\""
        }
    },
    "post_install": "Remove-Item \"$dir\\`$*\", \"$dir\\Uninstall*\", \"$dir\\resources\\app-update.yml\" -Force -Recurse -ErrorAction SilentlyContinue",
    "shortcuts": [
        [
            "mStream Server.exe",
            "mStream",
            "--user-data-dir=\"$dir\\User Data\""
        ]
    ],
    "persist": "User Data",
    "checkver": {
        "url": "https://github.com/IrosTheBeggar/mStream/releases/latest/download/latest.yml",
        "regex": "version: ([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/IrosTheBeggar/mStream/releases/download/v$version/mStream-Server-Setup-$version.exe#/dl.7z"
            }
        },
        "hash": {
            "url": "$baseurl/latest.yml",
            "regex": "sha512:\\s*$base64"
        }
    }
}
