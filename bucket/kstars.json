{
    "version": "3.8.3",
    "description": "A feature-rich free astronomy software developed by KDE.",
    "homepage": "https://kstars.kde.org/",
    "license": "GPL-2.0-or-later",
    "architecture": {
        "64bit": {
            "url": "https://www.indilib.org/jdownloads/kstars/kstars-3.8.3.exe#/dl.7z",
            "hash": "111e7d81da14e8b0579ed5e6bcd36a0ca2a76a66f02cfca82bcc0cb889f3e859"
        }
    },
    "pre_install": "Get-ChildItem \"$dir\" 'kstars-*.7z' | Select-Object -First 1 -ExpandProperty FullName | Expand-7zipArchive -Destination \"$dir\" -Removal",
    "post_install": "Remove-Item \"$dir\\uninstall*\", \"$dir\\`$*\" -Force -Recurse -ErrorAction SilentlyContinue",
    "shortcuts": [
        [
            "bin\\kstars.exe",
            "KStars"
        ]
    ],
    "notes": "KStars is NOT portable.",
    "checkver": {
        "url": "https://kstars.kde.org/download/windows/",
        "regex": "kstars-([\\d.]+).exe"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://www.indilib.org/jdownloads/kstars/kstars-$version.exe#/dl.7z"
            }
        },
        "hash": {
            "url": "$url.sha256"
        }
    }
}
