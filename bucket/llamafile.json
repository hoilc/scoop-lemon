{
    "version": "0.10.4",
    "description": "Distribute and run LLMs with a single file.",
    "homepage": "https://github.com/mozilla-ai/llamafile",
    "license": "Apache-2.0",
    "architecture": {
        "64bit": {
            "url": "https://github.com/mozilla-ai/llamafile/releases/download/0.10.4/llamafile-0.10.4.zip",
            "extract_dir": "llamafile-0.10.4\\bin",
            "hash": "498ef0b06e0f6ec700ad2e96d13d7db264a70fef9ca099c133b56330ef96b4f0"
        }
    },
    "pre_install": [
        "$names = @('llamafile', 'whisperfile', 'zipalign')",
        "$names | ForEach-Object { Get-ChildItem \"$dir\" $_ | Select-Object -First 1 | Rename-Item -NewName \"$_.exe\"  }"
    ],
    "bin": [
        "llamafile.exe",
        "whisperfile.exe",
        [
            "zipalign.exe",
            "llamafile-zipalign"
        ]
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/mozilla-ai/llamafile/releases/download/$version/llamafile-$version.zip",
                "extract_dir": "llamafile-$version\\bin"
            }
        }
    }
}
