{
    "version": "0.10.2",
    "description": "Distribute and run LLMs with a single file.",
    "homepage": "https://github.com/mozilla-ai/llamafile",
    "license": "Apache-2.0",
    "architecture": {
        "64bit": {
            "url": "https://github.com/mozilla-ai/llamafile/releases/download/0.10.2/llamafile-0.10.2.zip",
            "extract_dir": "llamafile-0.10.2\\bin",
            "hash": "83a0aecd05df2e19f2280bf64f5d36b4d883ab3855b3679efff548092b129e76"
        }
    },
    "pre_install": [
        "$names = @('llamafile', 'whisperfile', 'zipalign')",
        "$names | ForEach-Object { Get-ChildItem \"$dir\" $_ | Select-Object -First 1 | Rename-Item -NewName \"$_.exe\"  }"
    ],
    "bin": [
        "llamafile.exe",
        "whisperfile.exe",
        [
            "zipalign.exe",
            "llamafile-zipalign"
        ]
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/mozilla-ai/llamafile/releases/download/$version/llamafile-$version.zip",
                "extract_dir": "llamafile-$version\\bin"
            }
        }
    }
}
