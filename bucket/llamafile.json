{
    "version": "0.10.1",
    "description": "Distribute and run LLMs with a single file.",
    "homepage": "https://github.com/mozilla-ai/llamafile",
    "license": "Apache-2.0",
    "architecture": {
        "64bit": {
            "url": "https://github.com/mozilla-ai/llamafile/releases/download/0.10.1/llamafile-0.10.1.zip",
            "extract_dir": "llamafile-0.10.1\\bin",
            "hash": "f079561416e3560c3f383c4d03bbe67a7c80a63d1b0526a3868c39ee4b30cb87"
        }
    },
    "pre_install": [
        "$names = @('llamafile', 'whisperfile', 'zipalign')",
        "$names | ForEach-Object { Get-ChildItem \"$dir\" $_ | Select-Object -First 1 | Rename-Item -NewName \"$_.exe\"  }"
    ],
    "bin": [
        "llamafile.exe",
        "whisperfile.exe",
        [
            "zipalign.exe",
            "llamafile-zipalign"
        ]
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/mozilla-ai/llamafile/releases/download/$version/llamafile-$version.zip",
                "extract_dir": "llamafile-$version\\bin"
            }
        }
    }
}
