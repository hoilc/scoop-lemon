{
    "version": "4.0.0-beta-1",
    "description": "Apache Tika is a toolkit for detecting and extracting metadata and structured text content from various documents using existing parser libraries.",
    "homepage": "https://tika.apache.org/",
    "license": "Apache-2.0",
    "url": "https://repo1.maven.org/maven2/org/apache/tika/tika-app/4.0.0-beta-1/tika-app-4.0.0-beta-1.jar#/tika-app.jar",
    "hash": "sha1:017ea954c3303c5ee88cf73960af44dfe8048e4b",
    "pre_install": [
        "Set-Content -Encoding ASCII -Path \"$dir\\tika.bat\" -Value \"@java -jar `\"%~dp0tika-app.jar`\" %*\"",
        "Set-Content -Encoding ASCII -Path \"$dir\\tika-app.bat\" -Value '@start javaw.exe -jar \"%~dp0tika-app.jar\" --gui'"
    ],
    "bin": "tika.bat",
    "shortcuts": [
        [
            "tika-app.bat",
            "Apache Tika"
        ]
    ],
    "suggest": {
        "JDK": [
            "java/openjdk",
            "java/temurin-jdk",
            "java/oraclejdk",
            "java/zulu-jdk"
        ]
    },
    "checkver": {
        "url": "https://repo1.maven.org/maven2/org/apache/tika/tika-app/maven-metadata.xml",
        "regex": "<latest>(.+?)</latest>"
    },
    "autoupdate": {
        "url": "https://repo1.maven.org/maven2/org/apache/tika/tika-app/$version/tika-app-$version.jar#/tika-app.jar",
        "hash": {
            "url": "$url.sha1"
        }
    }
}
