    "license": "LGPL-2.1-only",
    "url": "https://github.com/checkstyle/checkstyle/releases/download/checkstyle-13.5.0/checkstyle-13.5.0-all.jar#!/checkstyle.jar",
    "hash": "df1412c034958226fba40a0221e867cd386c3ad49c6f321cdfdcd4b8b94c554b",
    "pre_install": [
        "Set-Content -Encoding ASCII -Path \"$dir\\checkstyle-gui.bat\" -Value '@start javaw.exe -cp \"%~dp0checkstyle.jar\" com.puppycrawl.tools.checkstyle.gui.Main'",
        "@($manifest.bin) | ForEach-Object { $n = [IO.Path]::GetFileNameWithoutExtension($_); Set-Content -Encoding ASCII -Path \"$dir\\$n.bat\" -Value \"@java -jar `\"%~dp0$n.jar`\" %*\" }"
    ],
    "bin": "checkstyle.bat",
    "shortcuts": [
        [
            "checkstyle-gui.bat",
            "Checkstyle GUI"
        ]
    ],
    "suggest": {
        "JDK 11+": [
            "java/temurin17-jdk",
            "java/temurin11-jdk",
            "java/zulu17-jdk",
            "java/zulu11-jdk"
        ]
    },
    "checkver": {
        "url": "https://github.com/checkstyle/checkstyle/releases/latest",
        "regex": "/releases/tag/checkstyle-([\\d.]+)\""
    },
    "autoupdate": {
        "url": "https://github.com/checkstyle/checkstyle/releases/download/checkstyle-$version/checkstyle-$version-all.jar#!/checkstyle.jar"
    }
}
