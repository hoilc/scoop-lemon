{
    "version": "3.26.3",
    "description": "OBS Browser+ 是一款一款用于访问和管理华为云对象存储服务 OBS 的图形化工具，支持完善的桶管理和对象管理操作",
    "homepage": "https://support.huaweicloud.com/browsertg-obs/obs_03_1000.html",
    "license": "Proprietary",
    "architecture": {
        "64bit": {
            "url": "https://obs-community.obs.cn-north-1.myhuaweicloud.com/obsbrowserplus/win64/obs-browser-plus%20Setup%203.26.3.exe#/dl.7z",
            "hash": "sha512:9dea25fdb65bcdfa692350143cea86b9435664694fb3510a1eb04f0139527c254f34f099cc20a55b3cd1a5c0525d17f6375719b80078b4f03dc05e643e65a1b0"
        },
        "32bit": {
            "url": "https://obs-community.obs.cn-north-1.myhuaweicloud.com/obsbrowserplus/win32/obs-browser-plus%20Setup%203.26.3.exe#/dl.7z",
            "hash": "sha512:c7b16ff169a74daa6a06ef6e7a67e6d3aefd2be7f52c80c477801f7271598fc98b999b6832503e083080768f8e12e95c35bd08afea2e2f6cce2ba0173b6b5f11"
        }
    },
    "pre_install": "Get-ChildItem \"$dir\\`$PLUGINSDIR\\app-*.7z\" | Select-Object -First 1 -ExpandProperty FullName | Expand-7zipArchive -DestinationPath \"$dir\\\" -Removal",
    "post_install": "Remove-Item \"$dir\\`$*\", \"$dir\\uninstall*\", \"$dir\\resources\\app-update.yml\"  -Force -Recurse -ErrorAction SilentlyContinue",
    "shortcuts": [
        [
            "obs-browser-plus.exe",
            "OBS Browser+",
            "--user-data-dir=\"User Data\""
        ]
    ],
    "persist": "User Data",
    "checkver": {
        "url": "https://obs-community.obs.cn-north-1.myhuaweicloud.com/obsbrowserplus/win64/latest.yml",
        "regex": "version:\\s+([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://obs-community.obs.cn-north-1.myhuaweicloud.com/obsbrowserplus/win64/obs-browser-plus%20Setup%20$version.exe#/dl.7z"
            },
            "32bit": {
                "url": "https://obs-community.obs.cn-north-1.myhuaweicloud.com/obsbrowserplus/win32/obs-browser-plus%20Setup%20$version.exe#/dl.7z"
            }
        },
        "hash": {
            "url": "$baseurl/latest.yml",
            "regex": "(?sm)$basename\\s*sha512:\\s*$base64"
        }
    }
}
