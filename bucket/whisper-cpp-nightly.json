        ],
        [
            "whisper-talk-llama.exe",
            "whisper-cpp-talk-llama"
        ]
    ],
    "checkver": {
        "url": "https://github.com/ggml-org/whisper.cpp/actions/workflows/build.yml?query=branch%3Amaster+event%3Apush+is%3Asuccess",
        "regex": "(?sm)/actions/runs/(?<run>\\d+)\".*?#(\\d+):"
    },
