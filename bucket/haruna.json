{
    "version": "1.7.1",
    "description": "An open source media player built with Qt/QML and libmpv.",
    "homepage": "https://apps.kde.org/haruna/",
    "license": "GPL-3.0-or-later",
    "architecture": {
        "64bit": {
            "url": "https://download.kde.org/stable/haruna/1.7.1/haruna-1.7.1-windows-gcc-x86_64.7z",
            "hash": "f38db1f204c996b890423c8f11fac07f8c4153cd9beee92214efa5036f7c07ef"
        }
    },
    "bin": "bin\\haruna.exe",
    "shortcuts": [
        [
            "bin\\haruna.exe",
            "Haruna"
        ]
    ],
    "notes": "Haruna is NOT portable.",
    "checkver": {
        "url": "https://apps.kde.org/haruna/index.xml",
        "regex": "/#([\\d.]+)</guid>"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://download.kde.org/stable/haruna/$version/haruna-$version-windows-gcc-x86_64.7z"
            }
        },
        "hash": {
            "url": "$url.sha256"
        }
    }
}
