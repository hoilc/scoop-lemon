{
    "version": "1.8.0",
    "description": "An open source media player built with Qt/QML and libmpv.",
    "homepage": "https://apps.kde.org/haruna/",
    "license": "GPL-3.0-or-later",
    "architecture": {
        "64bit": {
            "url": "https://download.kde.org/stable/haruna/1.8.0/haruna-1.8.0-windows-gcc-x86_64.7z",
            "hash": "38bef3164d7ffddc1bcfdb7ec4abd1fdd99237f1059a588684a7db9ff9fb6266"
        }
    },
    "bin": "bin\\haruna.exe",
    "shortcuts": [
        [
            "bin\\haruna.exe",
            "Haruna"
        ]
    ],
    "notes": "Haruna is NOT portable.",
    "checkver": {
        "url": "https://apps.kde.org/haruna/index.xml",
        "regex": "/#([\\d.]+)</guid>"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://download.kde.org/stable/haruna/$version/haruna-$version-windows-gcc-x86_64.7z"
            }
        },
        "hash": {
            "url": "$url.sha256"
        }
    }
}
