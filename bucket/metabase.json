{
    "version": "0.61.3",
    "description": "Metabase is the easy, open source way for everyone in your company to ask questions and learn from data.",
    "homepage": "https://github.com/metabase/metabase",
    "license": "AGPL-3.0-only",
    "url": "https://downloads.metabase.com/v0.61.3/metabase.jar",
    "hash": "935f07d8573f9c54fdb744e46a0af930d24221fae1f0b1d16e4e88e1f8a719b8",
    "pre_install": "@($manifest.bin) | ForEach-Object { $n = [IO.Path]::GetFileNameWithoutExtension($_); Set-Content -Encoding ASCII -Path \"$dir\\$n.bat\" -Value \"@java -jar `\"%~dp0$n.jar`\" %*\" }",
    "bin": "metabase.bat",
    "suggest": {
        "JDK": [
            "java/oraclejdk",
            "java/openjdk",
            "java/adoptopenjdk-hotspot",
            "java/zulu"
        ]
    },
    "env_set": {
        "MB_PLUGINS_DIR": "$dir\\plugins",
        "MB_DB_FILE": "$dir\\data\\metabase.db"
    },
    "persist": [
        "data",
        "plugins"
    ],
    "checkver": {
        "url": "http://static.metabase.com/version-info.json",
        "jsonpath": "$.latest.version",
        "regex": "v([\\d.]+)"
    },
    "autoupdate": {
        "url": "https://downloads.metabase.com/v$version/metabase.jar",
        "hash": {
            "url": "https://github.com/metabase/metabase/releases/tag/v$version",
            "regex": "<code>$sha256"
        }
    }
}
